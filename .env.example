# --- Frontend (Vite) — safe to expose in the browser; never put SMTP secrets here ---
# Dev: Vite proxies /api → mail server (see vite.config.js). Defaults in code use /api/* in development.
VITE_QUOTE_API_URL=/api/quote
VITE_CONTACT_API_URL=/api/contact

# Optional UI hint only (real recipient is MAIL_TO_* on the server)
VITE_QUOTE_RECEIVER_EMAIL=service@yourshop.ca

# Production build: set to your public API origin if the app and API share a host, e.g. /api/quote
# or full URL https://api.yourshop.ca/quote

# --- Mail API (server/index.js) — keep these in .env on the machine running Node; do NOT prefix with VITE_ ---

# SMTP (required to send mail)
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password

# From header (required if SMTP_USER is not a valid mailbox From address)
# Example: "Northridge Auto Care" <service@yourshop.ca>
SMTP_FROM="Northridge Auto Care" <service@yourshop.ca>

# Inboxes for submissions (at least one path below must resolve)
MAIL_TO=service@yourshop.ca
# Optional overrides:
# MAIL_TO_QUOTE=quotes@yourshop.ca
# MAIL_TO_CONTACT=frontdesk@yourshop.ca
# Or use QUOTE_RECIPIENT_EMAIL / CONTACT_RECIPIENT_EMAIL instead of MAIL_TO_*

# API server
API_PORT=3001
# Comma-separated origins for CORS, or * (not recommended in production)
FRONTEND_ORIGIN=http://localhost:5173
