# Email address your backend should deliver quote requests to.
# Do not rely on exposing this in production without a server — see src/services/quoteService.js
VITE_QUOTE_RECEIVER_EMAIL=ameerhamza7110@gmail.com

# Optional: full URL for your quote API (POST JSON). Leave empty during UI-only development
# to use the built-in mock success path after validation.
# Example: https://api.yourshop.ca/v1/quote
VITE_QUOTE_API_URL=

# Optional: POST endpoint for the general contact form
VITE_CONTACT_API_URL=
